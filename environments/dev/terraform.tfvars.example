# Copy this file to terraform.tfvars and fill in the values for your dev tenant.
#
#     cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is gitignored so your credentials stay local.
# Do NOT commit terraform.tfvars under any circumstances.

# ----- Jamf Pro -----
jamfpro_instance_fqdn = "https://yourcompany-dev.jamfcloud.com"
jamfpro_client_id     = "00000000-0000-0000-0000-000000000000"
jamfpro_client_secret = "replace-with-your-jamf-pro-client-secret"

# ----- Jamf Platform -----
# base_url options:
#   https://us.apigw.jamf.com
#   https://eu.apigw.jamf.com
#   https://apac.apigw.jamf.com
jamfplatform_base_url      = "https://eu.apigw.jamf.com"
jamfplatform_tenant_id     = "00000000-0000-0000-0000-000000000000"
jamfplatform_client_id     = "00000000-0000-0000-0000-000000000000"
jamfplatform_client_secret = "replace-with-your-jamf-platform-client-secret"

# ----- Apple-issued tokens -----
# Place token files in:
#   support_files/device_enrollment_tokens/your-ade-token.p7m
#   support_files/volume_purchasing_tokens/your-vpp-token.vpptoken
ade_token_path_default = "support_files/device_enrollment_tokens/dev-ade.p7m"
vpp_token_path_default = "support_files/volume_purchasing_tokens/dev-vpp.vpptoken"

# ----- Wi-Fi profile -----
# wifi_ssid has a default ("Pretend Co Wi-Fi") in modules/jamfpro/variables.tf.
# wifi_password has no default and MUST be set here or via TF_VAR_wifi_password.
# wifi_ssid     = "Your Corporate Wi-Fi"
wifi_password = "replace-with-your-wifi-password"
